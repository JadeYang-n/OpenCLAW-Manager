# OpenCLAW Manager 环境变量配置
# 复制此文件为 .env 并填入实际值

# === 安全密钥 (生产环境必须设置) ===
# JWT 签名密钥 (32 字节 hex)
# 生成: openssl rand -hex 32
OCM_JWT_SECRET=

# AES-256 加密密钥 (32 字节 hex)
OCM_AES_KEY=

# 审计日志 HMAC 密钥 (32 字节 hex)
OCM_AUDIT_SECRET=

# JWT 过期时间 (秒，默认 86400 = 24h)
# OCM_JWT_EXPIRES_IN=86400

# === 应用配置 ===
# 调试模式 (true=自动生成密钥，生产环境必须为 false)
OCM_DEBUG=false

# === 服务器配置 ===
# 监听地址和端口
# OCM_HOST=0.0.0.0
# OCM_PORT=8080
# 工作线程数 (默认 = CPU 核心数)
# OCM_WORKERS=4

# CORS 允许的源 (逗号分隔)
# OCM_CORS_ORIGINS=http://localhost:5173,http://example.com

# === 数据库配置 ===
# 数据库路径 (默认: 可执行文件同级的 data/ocm.db)
# OCM_DB_PATH=/var/lib/ocm/ocm.db
