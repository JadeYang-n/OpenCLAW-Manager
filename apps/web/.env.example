# OpenCLAW Manager 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# API 基础地址（后端服务地址）
# 开发环境：http://localhost:8080/api/v1
# 生产环境：根据实际部署地址配置
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Node.js 服务地址（开发环境）
VITE_NODE_SERVICE_URL=http://localhost:3456

# 生产环境使用 Tauri invoke，此配置仅用于开发环境健康检查
# 生产环境下 Node.js 服务由 Tauri 自动启动
